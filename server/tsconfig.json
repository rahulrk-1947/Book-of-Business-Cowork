{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist-server",
    "rootDir": "..",
    "noEmitOnError": true
  },
  "include": ["src/**/*.ts", "../src/backend/**/*.ts"]
}
